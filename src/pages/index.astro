              <div class="swiper-slide"><img src="/files/slide9.jpg" alt="Trilogy portfolio" /></div>
              <div class="swiper-slide"><img src="/files/slide8.jpg" alt="Trilogy portfolio" /></div>
              <div class="swiper-slide"><img src="/files/slide7.jpg" alt="Trilogy portfolio" /></div>
              <div class="swiper-slide"><img src="/files/slide1.jpg" alt="Ford Focus RS" /></div>
              <div class="swiper-slide"><img src="/files/slide2.jpg" alt="Nissan 350Z" /></div>
              <div class="swiper-slide"><img src="/files/slide3.jpg" alt="Audi Estate RS6" /></div>
              <div class="swiper-slide"><img src="/files/slide4.jpg" alt="Porsche" /></div>
