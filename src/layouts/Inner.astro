---
import Base from './Base.astro'
import Sidebar from '../components/Sidebar.astro'

interface Breadcrumb {
  label: string
  href?: string
}

interface Props {
  title: string
  description?: string
  breadcrumbs: Breadcrumb[]
}

const { title, description, breadcrumbs } = Astro.props
const hasSidebarSlot = Astro.slots.has('sidebar')
---

<Base title={title} description={description}>

  <div id="breadcrumbs">
    <div class="wrapper">
      <p>You are here: </p>
      <ul>
        {breadcrumbs.map((crumb, i) => (
          <li class={i === breadcrumbs.length - 1 ? 'current_crumb' : ''}>
            {crumb.href
              ? <a href={crumb.href}>{crumb.label}</a>
              : crumb.label}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="wrapper inner-grid">

    <div id="main_content">
      <slot />
    </div>

    <div id="sidebar">
      {hasSidebarSlot ? <slot name="sidebar" /> : <Sidebar />}
    </div>

  </div>

</Base>
